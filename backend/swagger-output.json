                                    "type": "number",
                                    "example": 1
                                }
                            }
                        },
                        "description": "Task ID"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Task updated successfully",
                        "content": {
                            "application/json": {
                                "schema": {
